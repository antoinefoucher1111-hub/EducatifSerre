        "name": "Générateur Météo",
        "func": "// On génère des valeurs qui changent à chaque exécution !\n\nmsg.payload = {\n    air: {\n        temp: Math.round((Math.random() * 15 + 15) * 10) / 10, // Varie entre 15.0 et 30.0 °C\n        hum: Math.round(Math.random() * 40 + 30)               // Varie entre 30 et 70 %\n    },\n    sol_moyenne: {\n        temp: Math.round((Math.random() * 10 + 12) * 10) / 10, // Varie entre 12.0 et 22.0 °C\n        hum: Math.round(Math.random() * 60 + 20)               // Varie entre 20 et 80 %\n    },\n    lumiere: Math.round(Math.random() * 900 + 100),            // Varie entre 100 et 1000 Lux\n    erreurs: false\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
